{
  "version": 2,
  "builds": [
    {
      "src": "app/static/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/static/(.*)",
      "dest": "app/static/$1"
    },
    {
      "src": "^/(.*\\.(css|js|png|jpg|svg|ico|json))",
      "dest": "app/static/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "app/static/index.html"
    }
  ]
}
